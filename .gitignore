# ignore everything in this virtualenv-root folder by default
*

# keep git metadata files trackable
!.gitignore

# track research engine code
!engine/
!engine/*.py

# track the main execution notebook
!0315 windows이사.ipynb

# track Phase 3 live trading system
!phase3/
!phase3/*.py
!phase3/*.yaml
!phase3/*.command
!phase3/*.md
phase3/config.local.yaml
phase3/config.yaml.bak_*

# track Phase 3 plans, reports and evaluation outputs
!phase3/docs/
!phase3/docs/*.md
!phase3/docs/*.json
!phase3/docs/*.jsonl

# track Phase 3 tests / evaluation scripts
!phase3/tests/
!phase3/tests/*.py
phase3/tests/__pycache__/

# track Phase 3 exit-stack research scripts
!phase3/exits/
!phase3/exits/*.py
phase3/exits/__pycache__/

# track Phase 3 autotrade package (KIS broker adapter etc.).
# IMPORTANT: .env stays IGNORED (default-deny via `*` at top); only .env.example is whitelisted.
!phase3/autotrade/
!phase3/autotrade/*.py
!phase3/autotrade/*.md
phase3/autotrade/__pycache__/
phase3/autotrade/logs/
!.env.example

# track Phase 3 signal transition artifacts (xlsx kept for research history)
!phase3/signal_transitions/
!phase3/signal_transitions/*.xlsx

# track project-level docs
!CONTEXT.md
!ARTIFACT_SCHEMA_V1.md

# track supporting tools
!fmp_cache_updater.py
!fmp_daily_updater.ipynb

# track archive for reference
!archive/
!archive/*.py

# track operator launchers (double-click panels). No secrets baked in;
# they only load identity keys from .env at runtime.
!scripts/
!scripts/*.command
!scripts/*.sh

# track Phase 3 launchd agents (plist TEMPLATES + installer).
# Installed plists with real paths live in ~/Library/LaunchAgents (untracked).
!phase3/launchd/
!phase3/launchd/*.template
!phase3/launchd/*.sh
!phase3/launchd/*.md
