# KIS Broker — template file.
# Copy this to `.env` (which is gitignored) and fill in real values.
#
#   cp .env.example .env
#   chmod 600 .env
#
# Never commit .env. The repo's .gitignore denies it by default.

# ---- Credentials (KIS Developers portal) --------------------------------
KIS_APP_KEY=
KIS_APP_SECRET=

# Account: "NNNNNNNN-PP" → split into front 8 digits and product code 2 digits.
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01

# ---- Environment selector ------------------------------------------------
# 'paper' (모의투자) or 'live' (실거래). Start with paper.
KIS_ENV=paper

# Live-order kill switch. Even with KIS_ENV=live, real orders only fire when
# this is set to 'true' AND the call site passes dry_run=False.
# Governs the LIVE-CAPITAL submit gate.
KIS_CONFIRM_LIVE=false

# Paper-broker submit switch. Even with KIS_ENV=paper, dry_run=False still
# returns a dry-run record unless this is set to 'true'. Governs the PAPER
# submit gate; cannot unlock live capital.
KIS_PAPER_SUBMIT_OK=false

# ---- Paths (optional; leave blank for sensible defaults) ----------------
# Default: ~/.kis_token_cache.json
KIS_TOKEN_CACHE_PATH=
# Default: ~/.kis_audit/
KIS_LOG_DIR=
